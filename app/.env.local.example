# Copy file này thành .env.local (hoặc .env) rồi dán giá trị thật vào — .env.local khớp mẫu *.local
# trong .gitignore nên KHÔNG commit; .env thì KHÔNG được .gitignore che, tự cân nhắc trước khi commit.
# Sau khi tạo/sửa file env phải KHỞI ĐỘNG LẠI `npm run dev` (Vite chỉ đọc lúc khởi động).

VITE_GROQ_API_KEY=gsk_dan_key_groq_that_cua_ban_vao_day

# Lấy ở Supabase Dashboard -> Project Settings -> API (mục "Publishable key")
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=dan_publishable_key_that_vao_day
